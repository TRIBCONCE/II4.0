    # Переводим пользователя в состояние ожидания канала
    await fsm.set_state(message.sender.huid, AddUserFSM.WAIT_FOR_CHANNEL)
    
    await bot.answer_message(
        body="Привет! Я бот для массового добавления пользователей.\n\n"
             "Пришли мне название целевого канала или группы в формате `##имяканала`.\n"
             "*Обязательно выбери канал из всплывающего синего списка мессенджера!*"
    )


@fsm.on(AddUserFSM.WAIT_FOR_CHANNEL)
async def process_channel_mention(message: IncomingMessage, bot: Bot) -> None:
    """Шаг 1: Ожидаем ввод канала и проверяем права."""
    chat_id = None
    chat_name = "Неизвестный канал"
    
    # Парсим ID канала (используем наш сырой парсер)
    raw_cmd = getattr(message, "raw_command", {})
    if hasattr(raw_cmd, "dict"): raw_cmd = raw_cmd.dict()
    elif not isinstance(raw_cmd, dict): raw_cmd = vars(raw_cmd) if hasattr(raw_cmd, "__dict__") else {}
        
    for entity in raw_cmd.get("entities", []):
        e_dict = entity.dict() if hasattr(entity, "dict") else (entity if isinstance(entity, dict) else {})
        if e_dict.get("type") == "mention":
            data = e_dict.get("data", {})
            if data.get("mention_type") in ("chat", "channel"):
                chat_id = data.get("mention_data", {}).get("group_chat_id")
                chat_name = data.get("mention_data", {}).get("name", chat_name)
                break

    if not chat_id:
        await bot.answer_message("Я не вижу канала. Убедись, что используешь `##имя` и выбираешь его из списка!")
        return

    # Проверяем права
    await bot.answer_message(body=f"⏳ Проверяю права в канале **{chat_name}**...")
    status = await check_bot_admin_rights(bot, str(chat_id), chat_name)
    
    if status == "ADMIN":
        # Успех! Переводим в следующее состояние
        await fsm.set_state(message.sender.huid, AddUserFSM.WAIT_FOR_ACTION)
        
        # Сохраняем chat_id в стейт, чтобы использовать позже
        await fsm.update_state_data(message.sender.huid, {"target_chat_id": str(chat_id), "target_chat_name": chat_name})
        
        markup = BubbleMarkup()
        markup.add_button(command="/add_by_dept", label="Добавить по подразделению")
        
        await bot.answer_message(
            body=f"✅ Отлично! Я администратор в канале **{chat_name}**.\n\nЧто будем делать дальше?",
            bubbles=markup
        )
    elif status == "MEMBER":
        await bot.answer_message(f"⚠️ Я есть в канале **{chat_name}**, но у меня НЕТ прав администратора. Дайте мне права и повторите ввод канала.")
    else:
        await bot.answer_message(f"❌ Меня нет в канале **{chat_name}**. Добавьте меня, выдайте права администратора и повторите ввод канала.")


@fsm.on(AddUserFSM.WAIT_FOR_ACTION)
async def process_action_selection(message: IncomingMessage, bot: Bot) -> None:
    """Шаг 2: Обрабатываем нажатие кнопки меню."""
    if message.body == "/add_by_dept":
        await fsm.set_state(message.sender.huid, AddUserFSM.WAIT_FOR_DEPT)
        await bot.answer_message(
            body="Введите часть названия подразделения (например, `сопровожд`):\n"
                 "*Поиск будет выполнен по полям department, division, extensionAttribute3 и 4*"
        )
    else:
        await bot.answer_message("Пожалуйста, выберите действие с помощью кнопок.")


@fsm.on(AddUserFSM.WAIT_FOR_DEPT)
async def process_dept_search(message: IncomingMessage, bot: Bot) -> None:
    """Шаг 3: Ищем подразделение в AD и Express."""
    search_str = message.body.strip()
    
    if len(search_str) < 3:
        await bot.answer_message("Пожалуйста, введите минимум 3 символа для поиска.")
        return
        
    await bot.answer_message(f"⏳ Выполняю поиск по подразделениям в Active Directory по запросу «{search_str}»...")
    
    try:
        # 1. Поиск в AD
        ad_results = await search_ad_departments(search_str)
        
        if not ad_results:
            await bot.answer_message(f"По запросу «{search_str}» подразделений в AD не найдено. Попробуйте другую часть названия.")
            return
            
        # Формируем красивый вывод
        reply_lines = ["**Найдено в Active Directory:**"]
        for dept, count in ad_results.items():
            reply_lines.append(f"• {dept} — {count} чел.")
            
        # 2. Выгрузка из Express
        await bot.answer_message(body="\n".join(reply_lines))
        await bot.answer_message(body="⏳ Подсчитываю общее количество активных пользователей в Express...")
        
        express_count = await count_express_users()
        
        await bot.answer_message(
            body=f"📊 **Сводка по Express:**\nВсего активных пользователей в мессенджере: {express_count} чел.\n\n"
                 f"*(Дальше мы сделаем кнопки для выбора конкретного подразделения из списка)*"
        )
        
    except Exception as e:
        await bot.answer_message(body=f"❌ Произошла ошибка при поиске: `{e}`")


