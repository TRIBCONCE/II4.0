@collector.default_message_handler
async def default_handler(message: IncomingMessage, bot: Bot) -> None:
    chat_id = None
    chat_name = "Неизвестный канал"
    
    try:
        # Достаем оригинальный сырой запрос от платформы Express
        raw_cmd = getattr(message, "raw_command", {})
        
        # На всякий случай переводим в словарь, если библиотека вернула объект
        if hasattr(raw_cmd, "dict"):
            raw_cmd = raw_cmd.dict()
        elif not isinstance(raw_cmd, dict):
            raw_cmd = vars(raw_cmd) if hasattr(raw_cmd, "__dict__") else {}
            
        # Идем в список entities
        entities = raw_cmd.get("entities", [])
        
        for entity in entities:
            # Тоже страхуемся от объектов
            e_dict = entity.dict() if hasattr(entity, "dict") else (entity if isinstance(entity, dict) else {})
            
            # Ищем mention типа chat или channel
            if e_dict.get("type") == "mention":
                data = e_dict.get("data", {})
                if data.get("mention_type") in ("chat", "channel"):
                    m_data = data.get("mention_data", {})
                    chat_id = m_data.get("group_chat_id")
                    chat_name = m_data.get("name", chat_name)
                    break  # Нашли канал, выходим из цикла
                    
    except Exception as e:
        await bot.answer_message(body=f"❌ Ошибка парсинга: {e}")
        return

    # Принимаем решение
    if chat_id:
        await bot.answer_message(body=f"⏳ Проверяю права для канала **{chat_name}**...")
        result_msg = await check_bot_admin_rights(bot, str(chat_id), chat_name)
        await bot.answer_message(body=result_msg)
    else:
        await bot.answer_message(
            body="Я не нашел скрытую ссылку на канал в твоем сообщении.\n\n"
                 "Убедись, что ты ввел `##имя` и **обязательно кликнул на канал из всплывающего списка**!"
        )