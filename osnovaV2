from pybotx import Bot, HandlerCollector, IncomingMessage, BubbleMarkup

# Создаем коллектор обработчиков
collector = HandlerCollector()


@collector.command("/start", description="Запуск бота")
async def start_handler(message: IncomingMessage, bot: Bot) -> None:
    """Обработчик команды /start. Отправляет кнопку пользователю."""

    # В Express кнопки называются баблами и создаются через BubbleMarkup
    markup = BubbleMarkup()
    markup.add_button(command="/say_hello", label="Нажми меня")

    # Отправляем сообщение, прикрепляя созданные кнопки в параметр bubbles
    await bot.answer_message(
        body="Привет! Нажми на кнопку ниже:",
        bubbles=markup,
    )


@collector.command("/say_hello", visible=False)
async def say_hello_handler(message: IncomingMessage, bot: Bot) -> None:
    """Обработчик нажатия на кнопку. visible=False скрывает команду из меню бота."""

    # При нажатии на кнопку присылаем текст "Привет"
    await bot.answer_message(body="Привет")


# Используем правильный декоратор для всех остальных сообщений
@collector.default_message_handler
async def default_handler(message: IncomingMessage, bot: Bot) -> None:
    await bot.answer_message(body="Я понимаю только команду /start. Введи её, чтобы появилась кнопка!")