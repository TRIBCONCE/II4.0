@collector.command("/start", description="Запуск бота")
async def start_handler(message: IncomingMessage, bot: Bot) -> None:
    user_huid = str(message.sender.huid)
    USER_STATES[user_huid] = {"state": "WAIT_FOR_CHANNEL"}

    await bot.answer_message(
        body="Привет! Я бот для массового добавления пользователей.\n\n"
             "Пришли мне название целевого канала или группы в формате `##имяканала`.\n"
             "*Обязательно выбери канал из всплывающего синего списка мессенджера!*"
    )


@collector.command("/add_by_dept", visible=False)
async def add_by_dept_handler(message: IncomingMessage, bot: Bot) -> None:
    user_huid = str(message.sender.huid)
    user_data = USER_STATES.get(user_huid, {})

    if user_data.get("state") != "WAIT_FOR_ACTION":
        await bot.answer_message("Сначала выберите канал с помощью команды /start.")
        return

    USER_STATES[user_huid]["state"] = "WAIT_FOR_DEPT"

    await bot.answer_message(
        body="Введите часть названия подразделения (например, `сопровожд`):\n"
             "*Поиск будет выполнен по полям department, division, extensionAttribute3 и 4*"
    )


@collector.default_message_handler
async def default_handler(message: IncomingMessage, bot: Bot) -> None:
    user_huid = str(message.sender.huid)
    user_data = USER_STATES.get(user_huid, {})
    current_state = user_data.get("state")

    # ─── ЕСЛИ ЖДЕМ ВВОДА КАНАЛА ───
    if current_state == "WAIT_FOR_CHANNEL":
        chat_id = None
        chat_name = "Неизвестный канал"

        raw_cmd = getattr(message, "raw_command", {})
        if hasattr(raw_cmd, "dict"):
            raw_cmd = raw_cmd.dict()
        elif not isinstance(raw_cmd, dict):
            raw_cmd = vars(raw_cmd) if hasattr(raw_cmd, "__dict__") else {}

        for entity in raw_cmd.get("entities", []):
            e_dict = entity.dict() if hasattr(entity, "dict") else (entity if isinstance(entity, dict) else {})
            if e_dict.get("type") == "mention":
                data = e_dict.get("data", {})
                if data.get("mention_type") in ("chat", "channel"):
                    chat_id = data.get("mention_data", {}).get("group_chat_id")
                    chat_name = data.get("mention_data", {}).get("name", chat_name)
                    break

        if not chat_id:
            await bot.answer_message("Я не вижу канала. Убедись, что используешь `##имя` и выбираешь его из списка!")
            return

        await bot.answer_message(body=f"⏳ Проверяю права в канале **{chat_name}**...")
        status = await check_bot_admin_rights(bot, str(chat_id), chat_name)

        if status == "ADMIN":
            USER_STATES[user_huid]["target_chat_id"] = str(chat_id)
            USER_STATES[user_huid]["target_chat_name"] = chat_name
            USER_STATES[user_huid]["state"] = "WAIT_FOR_ACTION"

            markup = BubbleMarkup()
            markup.add_button(command="/add_by_dept", label="Добавить по подразделению")

            await bot.answer_message(
                body=f"✅ Отлично! Я администратор в канале **{chat_name}**.\n\nЧто будем делать дальше?",
                bubbles=markup
            )
        elif status == "MEMBER":
            await bot.answer_message(f"⚠️ Я есть в канале **{chat_name}**, но у меня НЕТ прав администратора.")
        else:
            await bot.answer_message(f"❌ Меня нет в канале **{chat_name}**. Добавьте меня и выдайте права администратора.")
        return

    # ─── ЕСЛИ ЖДЕМ ВВОДА НАЗВАНИЯ ПОДРАЗДЕЛЕНИЯ ───
    elif current_state == "WAIT_FOR_DEPT":
        search_str = message.body.strip()

        if len(search_str) < 3:
            await bot.answer_message("Пожалуйста, введите минимум 3 символа для поиска.")
            return

        await bot.answer_message(f"⏳ Выполняю поиск в Active Directory по запросу «{search_str}»...")

        try:
            ad_results = await search_ad_departments(search_str)

            if not ad_results:
                await bot.answer_message(f"По запросу «{search_str}» целевых подразделений не найдено. Попробуйте другую часть названия.")
                return

            # Формируем итоговый чистый вывод
            reply_lines = ["**Найдено:**"]
            for dept, count in ad_results.items():
                reply_lines.append(f"• {dept} — {count} чел.")

            await bot.answer_message(body="\n".join(reply_lines))
            await bot.answer_message(body="⏳ Подсчитываю общее количество активных пользователей в Express...")

            express_count = await count_express_users()

            await bot.answer_message(
                body=f"📊 **Сводка по Express:**\nВсего активных пользователей в мессенджере: {express_count} чел.\n\n"
                     f"*(Дальше мы сделаем кнопки для выбора конкретного подразделения из списка)*"
            )

        except Exception as e:
            await bot.answer_message(body=f"❌ **Произошла ошибка при поиске:**\n`{e}`")
            
        return

    # ─── ЕСЛИ СОСТОЯНИЯ НЕТ ───
    await bot.answer_message(body="Введите `/start`, чтобы начать работу с ботом.")