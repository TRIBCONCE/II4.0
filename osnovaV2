LDAP_PASSWORD = "твой_пароль"
LDAP_SEARCH_BASE = "DC=abb-win,DC=ru"

def search_ad_departments_sync(search_str: str) -> dict:
    tls_config = Tls(validate=ssl.CERT_NONE, version=ssl.PROTOCOL_TLSv1_2)
    server = Server("abb-win.akbars.ru", port=636, use_ssl=True, get_info=ALL, tls=tls_config)
    conn = Connection(server, user=LDAP_USER, password=LDAP_PASSWORD, auto_bind=True, auto_referrals=False)

    search_str = search_str.lower()

    # Автоматически получаем правильный корень домена
    try:
        real_search_base = server.info.other.get('defaultNamingContext')[0]
    except Exception:
        real_search_base = "DC=abb-win,DC=akbars,DC=ru"

    ldap_filter = (
        f"(&(objectCategory=person)(objectClass=user)"
        f"(!(userAccountControl:1.2.840.113556.1.4.803:=2))"
        f"(|(department=*{search_str}*)(division=*{search_str}*)"
        f"(extensionAttribute3=*{search_str}*)(extensionAttribute4=*{search_str}*)))"
    )

    attributes = [
        'sAMAccountName', 'name', 'displayName', 'employeeType',
        'department', 'division', 'extensionAttribute3', 'extensionAttribute4',
        'distinguishedName'
    ]

    conn.search(search_base=real_search_base, search_filter=ldap_filter, search_scope=SUBTREE, attributes=attributes)

    results = {}

    for entry in conn.entries:
        sam = str(entry.sAMAccountName.value).strip().lower() if entry.sAMAccountName else ""
        name = str(entry.name.value).lower() if entry.name else ""
        dn = str(entry.distinguishedName.value).lower() if entry.distinguishedName else ""
        emp_type = str(entry.employeeType.value).strip().lower() if entry.employeeType else ""

        # Проверка наших исключений
        if (
                emp_type in ["service", "vendor"] or
                sam.startswith("health") or sam.startswith("audit") or
                sam.startswith("esas") or sam.startswith("a-") or sam.startswith("z-") or
                "$" in name or "администратор" in name or "тестовая" in name or
                "отключенные пользователи" in dn or "сторон" in dn
        ):
            continue

        dept_name = "Неизвестное подразделение"
        for attr in ['department', 'division', 'extensionAttribute3', 'extensionAttribute4']:
            val = getattr(entry, attr).value if hasattr(entry, attr) else None
            if val and search_str in str(val).lower():
                dept_name = str(val)
                break

        if dept_name not in results:
            results[dept_name] = 0
        results[dept_name] += 1

    conn.unbind()
    return results


async def search_ad_departments(search_str: str) -> dict:
    return await asyncio.to_thread(search_ad_departments_sync, search_str)


# ─── 2. ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ API ───────────────────────────────────────

async def get_botx_token(bot_id_str: str, cts_url: str) -> str:
    secret_bytes = settings.express.secret_key.encode('utf-8')
    bot_id_bytes = bot_id_str.encode('utf-8')
    signature = hmac.new(secret_bytes, bot_id_bytes, hashlib.sha256).hexdigest().upper()

    async with httpx.AsyncClient() as client:
        token_url = f"{cts_url}/api/v2/botx/bots/{bot_id_str}/token?signature={signature}"
        resp = await client.get(token_url)
        resp.raise_for_status()
        return resp.json().get("result")


async def check_bot_admin_rights(bot: Bot, chat_id_str: str, chat_name: str) -> str:
    bot_id_str = str(settings.express.uuid)
    cts_url = str(settings.express.cts_url).rstrip("/")

    try:
        token = await get_botx_token(bot_id_str, cts_url)
        async with httpx.AsyncClient() as client:
            info_url = f"{cts_url}/api/v3/botx/chats/info?group_chat_id={chat_id_str}"
            headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}

            info_resp = await client.get(info_url, headers=headers)
            if info_resp.status_code in (403, 404):
                return "NOT_FOUND"

            info_resp.raise_for_status()
            chat_data = info_resp.json().get("result", {})

            for member in chat_data.get("members", []):
                if str(member.get("user_huid")) == bot_id_str:
                    return "ADMIN" if member.get("admin", False) else "MEMBER"
            return "NOT_FOUND"
    except Exception:
        return "ERROR"


async def count_express_users() -> int:
    bot_id_str = str(settings.express.uuid)
    cts_url = str(settings.express.cts_url).rstrip("/")
    token = await get_botx_token(bot_id_str, cts_url)

    async with httpx.AsyncClient(timeout=60.0) as client:
        csv_url = f"{cts_url}/api/v3/botx/users/users_as_csv"
        headers = {"Authorization": f"Bearer {token}"}
        params = {"cts_user": "true", "unregistered": "false", "botx": "false"}

        resp = await client.get(csv_url, headers=headers, params=params)
        resp.raise_for_status()

        csv_lines = resp.text.strip().split('\n')
        active_count = 0
        for line in csv_lines[1:]:
            columns = line.split(',')
            if len(columns) > 6 and columns[6].strip().lower() == "true":
                active_count += 1
        return active_count


