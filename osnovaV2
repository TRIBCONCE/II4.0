
import json

@collector.default_message_handler
async def default_handler(message: IncomingMessage, bot: Bot) -> None:
    try:
        # Превращаем объект сообщения в словарь (Pydantic или стандартный)
        msg_dict = message.dict() if hasattr(message, "dict") else vars(message)
        
        # Конвертируем в красивый текст
        debug_dump = json.dumps(msg_dict, indent=2, ensure_ascii=False, default=str)
        
        # Если есть сырой JSON от платформы (raw_command), достаем и его
        raw_cmd = getattr(message, "raw_command", "Нет поля raw_command")
        
        reply_text = (
            f"🕵️‍♂️ **Отладочная информация!**\n"
            f"Вот как библиотека видит твое сообщение:\n\n"
            f"```json\n{debug_dump}\n```\n\n"
            f"RAW:\n`{raw_cmd}`"
        )
        
        # Если текст слишком длинный, обрезаем, чтобы Express не выдал ошибку
        await bot.answer_message(body=reply_text[:4000])
        
    except Exception as e:
        await bot.answer_message(body=f"Ошибка дебага: {e}")