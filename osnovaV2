# ─── ЕСЛИ ЖДЕМ ВВОДА НАЗВАНИЯ ПОДРАЗДЕЛЕНИЯ ───
    elif current_state == "WAIT_FOR_DEPT":
        search_str = message.body.strip()
        
        if len(search_str) < 3:
            await bot.answer_message("Пожалуйста, введите минимум 3 символа для поиска.")
            return
            
        await bot.answer_message(f"⏳ Выполняю поиск в Active Directory по запросу «{search_str}»...")
        
        try:
            ad_results = await search_ad_departments(search_str)
            
            if not ad_results:
                await bot.answer_message(f"По запросу «{search_str}» подразделений в AD не найдено. Попробуйте другую часть названия.")
                return
                
            reply_lines = ["**Найдено в Active Directory:**"]
            for dept, count in ad_results.items():
                reply_lines.append(f"• {dept} — {count} чел.")
                
            await bot.answer_message(body="\n".join(reply_lines))
            await bot.answer_message(body="⏳ Подсчитываю общее количество активных пользователей в Express...")
            
            express_count = await count_express_users()
            
            await bot.answer_message(
                body=f"📊 **Сводка по Express:**\nВсего активных пользователей в мессенджере: {express_count} чел.\n\n"
                     f"*(Дальше мы сделаем кнопки для выбора конкретного подразделения из списка)*"
            )
            
        except Exception as e:
            # Получаем полный стек вызова ошибки
            error_details = traceback.format_exc()
            
            # Обрезаем, если текст слишком длинный для Express (оставляем последние 3500 символов)
            if len(error_details) > 3500:
                error_details = "..." + error_details[-3500:]
                
            await bot.answer_message(
                body=f"❌ **Произошла ошибка при поиске:**\n`{e}`\n\n"
                     f"🕵️‍♂️ **Трассировка для отладки:**\n```python\n{error_details}\n```"
            )
            
        return