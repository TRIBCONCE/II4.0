@collector.command("/start", description="Присоединиться к игре")
async def start_handler(message: IncomingMessage, bot: Bot) -> None:
    """Регистрирует участника в игре."""
    game = _game(bot)
    huid = str(message.sender.huid)
    name = message.sender.username or message.sender.ad_login or "Неизвестный"

    if huid in game.registered_players:
        await bot.answer_message("Вы уже зарегистрированы в игре. Ожидайте начала вопроса.")
        LOG.info(f"[start] Повторная регистрация: {name} ({huid})")
        return

    game.registered_players[huid] = name
    await bot.answer_message(
        "🎉 **Добро пожаловать на общебанковскую интеллектуальную игру!**\n\n"
        "Ожидайте начала вопроса от ведущего."
    )
    LOG.info(f"[start] Зарегистрирован: {name} ({huid}), всего игроков: {len(game.registered_players)}")


