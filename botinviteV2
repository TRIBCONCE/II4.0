@collector.command("/get_users", visible=False)
async def get_users_handler(message: IncomingMessage, bot: Bot) -> None:
    """Скачивает CSV с пользователями и выводит статистику."""
    await bot.answer_message(body="⏳ Запрашиваю базу пользователей у сервера. Это может занять несколько секунд...")
    
    bot_id_str = str(settings.express.uuid)
    cts_url = str(settings.express.cts_url).rstrip("/")
    
    try:
        token = await get_botx_token(bot_id_str, cts_url)
        
        async with httpx.AsyncClient(timeout=60.0) as client:
            csv_url = f"{cts_url}/api/v3/botx/users/users_as_csv"
            headers = {"Authorization": f"Bearer {token}"}
            # Параметры из доки: берем только cts_user, откидываем ботов
            params = {"cts_user": "true", "unregistered": "false", "botx": "false"}
            
            resp = await client.get(csv_url, headers=headers, params=params)
            resp.raise_for_status()
            
            # Разделяем ответ на строки
            csv_lines = resp.text.strip().split('\n')
            
            # Первая строка — это заголовки. Считаем пользователей:
            total_users = len(csv_lines) - 1 if len(csv_lines) > 0 else 0
            
            # (Опционально) Посчитаем только активных
            active_count = 0
            for line in csv_lines[1:]:
                # В CSV колонки: HUID, AD Login, Domain, AD E-mail, Name, Sync source, Active...
                # Флаг Active - 7-я колонка (индекс 6)
                columns = line.split(',')
                if len(columns) > 6 and columns[6].strip().lower() == "true":
                    active_count += 1

            await bot.answer_message(
                body=f"✅ База успешно выгружена!\n\n"
                     f"Всего пользователей: **{total_users}**\n"
                     f"Из них активных: **{active_count}**\n\n"
                     f"База готова для поиска по отделам (Сценарий B)."
            )
            
    except Exception as e:
        await bot.answer_message(body=f"❌ Произошла ошибка при скачивании базы:\n`{e}`")


@collector.default_message_handler
async def default_handler(message: IncomingMessage, bot: Bot) -> None:
    """Ловит упоминания каналов для проверки прав."""
    chat_id = None
    chat_name = "Неизвестный канал"
    
    try:
        raw_cmd = getattr(message, "raw_command", {})
        if hasattr(raw_cmd, "dict"):
            raw_cmd = raw_cmd.dict()
        elif not isinstance(raw_cmd, dict):
            raw_cmd = vars(raw_cmd) if hasattr(raw_cmd, "__dict__") else {}
            
        entities = raw_cmd.get("entities", [])
        
        for entity in entities:
            e_dict = entity.dict() if hasattr(entity, "dict") else (entity if isinstance(entity, dict) else {})
            if e_dict.get("type") == "mention":
                data = e_dict.get("data", {})
                if data.get("mention_type") in ("chat", "channel"):
                    m_data = data.get("mention_data", {})
                    chat_id = m_data.get("group_chat_id")
                    chat_name = m_data.get("name", chat_name)
                    break
    except Exception:
        pass

    if chat_id:
        await bot.answer_message(body=f"⏳ Проверяю права для канала **{chat_name}**...")
        result_msg = await check_bot_admin_rights(bot, str(chat_id), chat_name)
        await bot.answer_message(body=result_msg)
    else:
        await bot.answer_message(
            body="Команда не распознана. Для меню используй `/start`."
        )