import asyncio
import time
from uuid import UUID

from pybotx import (
    Bot,
    BubbleMarkup,
    ChatTypes,
    HandlerCollector,
    IncomingMessage,
)

from config import settings
from game_state import GameState

collector = HandlerCollector()

LOG = settings.logger
ADMIN_LOGIN = settings.game.admin_login.lower()
DISCUSSION_SEC = settings.game.timer_discussion   # 60
ANSWER_SEC = settings.game.timer_answer            # 10
TOTAL_SEC = DISCUSSION_SEC + ANSWER_SEC            # 70


