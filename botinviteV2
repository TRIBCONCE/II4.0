async def _question_timer(bot: Bot, question_num: int) -> None:
    """
    Фоновая задача: рассылает таймерные уведомления участникам.
    Расписание (от момента старта):
        0 сек  — «Вопрос N. У вас есть 60 секунд на обсуждение»
       30 сек  — «Осталось 30 секунд до конца обсуждения»
       50 сек  — «Осталось 10 секунд до конца обсуждения»
       60 сек  — «Время обсуждения истекло, у вас есть 10 секунд на отправку ответа»
       70 сек  — «Время на отправку ответов закончилось!»
    """
    game = _game(bot)

    try:
        # 0 сек — старт
        await _send_to_all_players(
            bot,
            f"❓ **Вопрос {question_num}.** У вас есть {DISCUSSION_SEC} секунд на обсуждение"
        )
        LOG.info(f"[timer] Вопрос {question_num} — отсчёт запущен")

        # Ждём 30 сек
        await asyncio.sleep(30)
        await _send_to_all_players(bot, "⏳ Осталось 30 секунд до конца обсуждения")
        LOG.info(f"[timer] Вопрос {question_num} — осталось 30 сек")

        # Ждём ещё 20 сек (итого 50)
        await asyncio.sleep(20)
        await _send_to_all_players(bot, "⏳ Осталось 10 секунд до конца обсуждения")
        LOG.info(f"[timer] Вопрос {question_num} — осталось 10 сек обсуждения")

        # Ждём ещё 10 сек (итого 60)
        await asyncio.sleep(10)
        await _send_to_all_players(
            bot,
            f"⌛ Время обсуждения истекло, у вас есть {ANSWER_SEC} секунд на отправку ответа"
        )
        LOG.info(f"[timer] Вопрос {question_num} — обсуждение закончилось, {ANSWER_SEC} сек на ответ")

        # Ждём ещё 10 сек (итого 70)
        await asyncio.sleep(ANSWER_SEC)
        await _send_to_all_players(bot, "🚫 Время на отправку ответов закончилось!")
        LOG.info(f"[timer] Вопрос {question_num} — время вышло, получено ответов: {len(game.answers)}")

        # Переводим состояние в IDLE
        game.status = "IDLE"

    except asyncio.CancelledError:
        LOG.info(f"[timer] Таймер вопроса {question_num} отменён")
        raise


