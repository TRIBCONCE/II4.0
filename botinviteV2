# src/bot.py

from uuid import UUID

import httpx
from pybotx import Bot, BotAccountWithSecret, HandlerCollector

from config import settings
from handlers import game


def create_bot() -> Bot:
    """Фабрика: создаёт и конфигурирует экземпляр бота."""

    main_collector = HandlerCollector()
    main_collector.include(game.collector)

    timeouts = httpx.Timeout(30.0, connect=5.0)
    limits = httpx.Limits(
        max_keepalive_connections=5,
        max_connections=10,
        keepalive_expiry=5,
    )
    httpx_client = httpx.AsyncClient(timeout=timeouts, limits=limits)

    return Bot(
        collectors=[main_collector],
        bot_accounts=[
            BotAccountWithSecret(
                id=UUID(str(settings.express.uuid)),
                cts_url=settings.express.cts_url,
                secret_key=settings.express.secret_key,
            ),
        ],
        httpx_client=httpx_client,
    )
