Теперь как будем искать пользователей вот тут очень важно ибо работать будем через Эктив директори следовательно выгрузим всех пользователей выгрузим из эктив директори но в обзор попадут пользователи вот по такому фильтру:  
$AllUsersOn = Get-ADUser `
        -Filter { enabled -eq $true } `
        -Properties department,division,extensionAttribute3,extensionAttribute4, samaccountname, displayName, name, whenCreated, employeeType 

$sam = ([string]$User.samaccountname).Trim()
        $name = $User.name
        $dn = $User.DistinguishedName

		if (
			$User.whenCreated -gt $LimitDate -or
			(@("service","vendor") -contains ([string]$User.employeeType).Trim().ToLower()) -or

			$sam -like "Health*" -or
			$sam -like "audit*" -or
			$sam -like "esas*" -or
			$sam -like "a-*" -or
			$sam -like "z-*" -or
			$name -like "*`$*" -or
			$name -like "*Администратор*" -or
			$name -like "*Тестовая*" -or
			$dn -like "*Отключенные пользователи*" -or
			$dn -like "*сторон*"

