def _game(bot: Bot) -> GameState:
    """Короткий доступ к состоянию игры."""
    return bot.state.game


def _is_admin(message: IncomingMessage) -> bool:
    login = message.sender.ad_login
    return bool(login and login.lower() == ADMIN_LOGIN)


def _bot_id(bot: Bot) -> UUID:
    return UUID(str(settings.express.uuid))


async def _send_to_all_players(bot: Bot, text: str) -> None:
    """Отправляет сообщение каждому зарегистрированному участнику."""
    game = _game(bot)
    bot_id = _bot_id(bot)
    for huid_str in game.registered_players:
        try:
            # Ищем личный чат с участником
            chat_id = await _get_or_create_personal_chat(bot, bot_id, UUID(huid_str))
            if chat_id:
                await bot.send_message(bot_id=bot_id, chat_id=chat_id, body=text)
        except Exception as e:
            LOG.error(f"Не удалось отправить сообщение игроку {huid_str}: {e}")


async def _get_or_create_personal_chat(bot: Bot, bot_id: UUID, user_huid: UUID) -> UUID | None:
    """Находит или создаёт личный чат бота с пользователем."""
    try:
        chats = await bot.list_chats(bot_id=bot_id)
        for chat in chats:
            if chat.chat_type == ChatTypes.PERSONAL_CHAT and user_huid in chat.members:
                return chat.chat_id
        # Если чат не найден — создаём
        chat_id = await bot.create_chat(
            bot_id=bot_id,
            name="Что? Где? Когда?",
            chat_type=ChatTypes.PERSONAL_CHAT,
            huids=[user_huid],
        )
        return chat_id
    except Exception as e:
        LOG.error(f"Ошибка при поиске/создании чата для {user_huid}: {e}")
        return None


async def _send_to_admin(bot: Bot, text: str) -> None:
    """Отправляет сообщение админу в личку."""
    bot_id = _bot_id(bot)
    try:
        admin_user = await bot.search_user_by_ad(
            bot_id=bot_id,
            ad_login=settings.game.admin_login,
            ad_domain="abb-win",
        )
        chat_id = await _get_or_create_personal_chat(bot, bot_id, admin_user.huid)
        if chat_id:
            await bot.send_message(bot_id=bot_id, chat_id=chat_id, body=text)
    except Exception as e:
        LOG.error(f"Не удалось отправить сообщение админу: {e}")


