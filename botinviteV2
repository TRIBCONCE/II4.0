async def on_shutdown() -> None:
    LOG.info("[shutdown] Остановка бота...")
    game: GameState = bot.state.game
    if game.timer_task and not game.timer_task.done():
        game.timer_task.cancel()
    await bot.shutdown()
    LOG.info("[shutdown] Бот остановлен.")


