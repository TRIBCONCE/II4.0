# src/routers/botx.py

from fastapi import APIRouter, Request, status
from fastapi.responses import JSONResponse
from pybotx import (
    Bot,
    BotXMethodCallbackNotFoundError,
    UnknownBotAccountError,
    UnverifiedRequestError,
    build_bot_disabled_response,
    build_command_accepted_response,
)

from src.config import settings
from src.routers.dependencies.bot_dependency import bot_dependency

router = APIRouter()
LOG = settings.logger


@router.post("/command", include_in_schema=False)
async def command_handler(request: Request, bot: Bot = bot_dependency) -> JSONResponse:
    data = await request.json()

    sender = data.get("from", {})
    cmd = data.get("command", {}).get("body", "")
    LOG.info(f"COMMAND: user={sender.get('username','?')} cmd={cmd}")

    try:
        bot.async_execute_raw_bot_command(data, request_headers=request.headers)
    except (ValueError, UnknownBotAccountError, UnverifiedRequestError) as exc:
        LOG.error(f"COMMAND_FAIL: {exc}")
        return JSONResponse(
            build_bot_disabled_response(str(exc)),
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
        )

    return JSONResponse(build_command_accepted_response(), status_code=status.HTTP_202_ACCEPTED)


@router.get("/status", include_in_schema=False)
async def status_handler(request: Request, bot: Bot = bot_dependency) -> JSONResponse:
    try:
        result = await bot.raw_get_status(
            dict(request.query_params), request_headers=request.headers
        )
    except UnknownBotAccountError as exc:
        return JSONResponse(
            build_bot_disabled_response(str(exc)),
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
        )
    return JSONResponse(result)


@router.post("/notification/callback", include_in_schema=False)
async def callback_handler(request: Request, bot: Bot = bot_dependency) -> JSONResponse:
    data = await request.json()
    try:
        await bot.set_raw_botx_method_result(
            data, request_headers=request.headers, verify_request=False
        )
    except BotXMethodCallbackNotFoundError as exc:
        return JSONResponse(
            build_bot_disabled_response(str(exc)),
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
        )
    return JSONResponse(build_command_accepted_response(), status_code=status.HTTP_202_ACCEPTED)

