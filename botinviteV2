import hmac
import hashlib
import httpx
from pybotx import Bot, HandlerCollector, IncomingMessage, BubbleMarkup

from src.config import settings

collector = HandlerCollector()

# ─── ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ДЛЯ API ──────────────────────────────────────

async def get_botx_token(bot_id_str: str, cts_url: str) -> str:
    """Генерирует подпись и получает токен для работы с BotX API."""
    secret_bytes = settings.express.secret_key.encode('utf-8')
    bot_id_bytes = bot_id_str.encode('utf-8')
    signature = hmac.new(secret_bytes, bot_id_bytes, hashlib.sha256).hexdigest().upper()
    
    async with httpx.AsyncClient() as client:
        token_url = f"{cts_url}/api/v2/botx/bots/{bot_id_str}/token?signature={signature}"
        resp = await client.get(token_url)
        resp.raise_for_status()
        
        token = resp.json().get("result")
        if not token:
            raise ValueError("Сервер не вернул токен")
        return token


async def check_bot_admin_rights(bot: Bot, chat_id_str: str, chat_name: str) -> str:
    """Проверяет права бота в конкретном чате."""
    bot_id_str = str(settings.express.uuid)
    cts_url = str(settings.express.cts_url).rstrip("/")
    
    try:
        token = await get_botx_token(bot_id_str, cts_url)
        
        async with httpx.AsyncClient() as client:
            info_url = f"{cts_url}/api/v3/botx/chats/info?group_chat_id={chat_id_str}"
            headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
            
            info_resp = await client.get(info_url, headers=headers)
            
            if info_resp.status_code in (403, 404):
                return (f"❌ Ошибка! Меня нет в канале **{chat_name}**.\n\n"
                        f"*Бот видит только те каналы и группы, в которых он уже состоит как администратор. "
                        f"Добавьте бота туда и назначьте ему права администратора, затем повторите поиск.*")
                
            info_resp.raise_for_status()
            chat_data = info_resp.json().get("result", {})
            
            is_admin = False
            for member in chat_data.get("members", []):
                if str(member.get("user_huid")) == bot_id_str:
                    is_admin = member.get("admin", False)
                    break
            
            real_chat_name = chat_data.get("name", chat_name)
            
            if is_admin:
                return f"✅ Я админ и добавлен в канал: **{real_chat_name}**"
            else:
                return f"⚠️ Я есть в канале **{real_chat_name}**, но у меня НЕТ прав администратора."
                
    except Exception as e:
        return f"❌ Ошибка при проверке прав: `{e}`"


