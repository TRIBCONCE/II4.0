@collector.default_message_handler
async def default_handler(message: IncomingMessage, bot: Bot) -> None:
    """
    Обрабатывает любой текст, не являющийся командой.
    Если идёт вопрос и время не вышло — принимает как ответ.
    """
    game = _game(bot)
    huid = str(message.sender.huid)
    name = message.sender.username or message.sender.ad_login or "Неизвестный"

    # Админу можно писать что угодно — игнорируем
    if _is_admin(message):
        return

    # Если пользователь не зарегистрирован — просим /start
    if huid not in game.registered_players:
        await bot.answer_message(
            "Для участия в игре отправьте команду /start"
        )
        return

    # ── Состояние IDLE ──
    if game.status == "IDLE":
        await bot.answer_message(
            "Вы не можете сейчас отправлять сообщения. "
            "Дождитесь сообщений администратора"
        )
        return

    # ── Состояние ACTIVE ──
    elapsed = time.time() - game.question_started_at

    if elapsed > TOTAL_SEC:
        # Опоздал
        await bot.answer_message("🚫 Время на отправку ответов закончилось!")
        return

    # Уже отвечал на этот вопрос?
    if huid in game.answers:
        await bot.answer_message("ℹ️ Ваш ответ уже принят. Повторная отправка невозможна.")
        return

    # Принимаем ответ
    answer_text = message.body.strip()
    game.answers[huid] = answer_text

    await bot.answer_message("✅ Ответ принят")
    LOG.info(
        f"[answer] Вопрос {game.question_number} — ответ от {name}: «{answer_text}» "
        f"(через {elapsed:.1f} сек)"
    )

    # Пересылаем админу
    await _send_to_admin(
        bot,
        f"📩 **Вопрос {game.question_number}** — {name} ответил:\n«{answer_text}»"
    )

