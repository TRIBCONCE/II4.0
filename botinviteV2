@collector.command("/q", description="Запустить следующий вопрос", visible=False)
async def question_handler(message: IncomingMessage, bot: Bot) -> None:
    """Админ запускает новый вопрос."""
    if not _is_admin(message):
        await bot.answer_message("❌ Эта команда доступна только ведущему.")
        return

    game = _game(bot)

    if game.status == "ACTIVE":
        await bot.answer_message("⚠️ Вопрос уже идёт. Дождитесь окончания или используйте /stop.")
        return

    if not game.registered_players:
        await bot.answer_message("⚠️ Нет зарегистрированных участников. Участники должны нажать /start.")
        return

    # Новый вопрос
    game.question_number += 1
    game.answers = {}
    game.status = "ACTIVE"
    game.question_started_at = time.time()

    # Запускаем фоновый таймер
    game.timer_task = asyncio.create_task(
        _question_timer(bot, game.question_number)
    )

    await bot.answer_message(
        f"✅ Вопрос **{game.question_number}** запущен.\n"
        f"Участников: **{len(game.registered_players)}**\n"
        f"Таймер: {TOTAL_SEC} сек ({DISCUSSION_SEC} обсуждение + {ANSWER_SEC} ответ)"
    )
    LOG.info(f"[q] Админ запустил вопрос {game.question_number}")


@collector.command("/stop", description="Остановить текущий вопрос", visible=False)
async def stop_handler(message: IncomingMessage, bot: Bot) -> None:
    """Админ принудительно останавливает текущий вопрос."""
    if not _is_admin(message):
        await bot.answer_message("❌ Эта команда доступна только ведущему.")
        return

    game = _game(bot)

    if game.status != "ACTIVE":
        await bot.answer_message("ℹ️ Сейчас нет активного вопроса.")
        return

    # Отменяем таймер
    if game.timer_task and not game.timer_task.done():
        game.timer_task.cancel()

    game.status = "IDLE"
    await _send_to_all_players(bot, "⛔ Ведущий остановил текущий вопрос.")
    await bot.answer_message(
        f"⛔ Вопрос {game.question_number} остановлен.\n"
        f"Получено ответов: **{len(game.answers)}**"
    )
    LOG.info(f"[stop] Админ остановил вопрос {game.question_number}")


@collector.command("/answers", description="Показать ответы", visible=False)
async def answers_handler(message: IncomingMessage, bot: Bot) -> None:
    """Админ смотрит собранные ответы на текущий/последний вопрос."""
    if not _is_admin(message):
        await bot.answer_message("❌ Эта команда доступна только ведущему.")
        return

    game = _game(bot)

    if game.question_number == 0:
        await bot.answer_message("ℹ️ Ещё не было ни одного вопроса.")
        return

    if not game.answers:
        await bot.answer_message(f"📋 **Вопрос {game.question_number}** — ответов пока нет.")
        return

    lines = [f"📋 **Ответы на вопрос {game.question_number}:**\n"]
    for idx, (huid, answer) in enumerate(game.answers.items(), 1):
        name = game.registered_players.get(huid, "Неизвестный")
        lines.append(f"**{idx}.** {name}: «{answer}»")

    await bot.answer_message("\n".join(lines))
    LOG.info(f"[answers] Админ запросил ответы, вопрос {game.question_number}")


